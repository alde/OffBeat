# .pkgmeta - CurseForge packaging configuration for OffBeat addon

package-as: OffBeat

externals:
  Libs/LibStub:
    url: https://repos.wowace.com/wow/libstub/trunk
    tag: latest

  Libs/CallbackHandler-1.0:
    url: https://repos.wowace.com/wow/callbackhandler/trunk/CallbackHandler-1.0
    tag: latest

  Libs/AceAddon-3.0:
    url: https://repos.wowace.com/wow/ace3/trunk/AceAddon-3.0
    tag: latest

  Libs/AceEvent-3.0:
    url: https://repos.wowace.com/wow/ace3/trunk/AceEvent-3.0
    tag: latest

  Libs/AceDB-3.0:
    url: https://repos.wowace.com/wow/ace3/trunk/AceDB-3.0
    tag: latest

  Libs/AceTimer-3.0:
    url: https://repos.wowace.com/wow/ace3/trunk/AceTimer-3.0
    tag: latest

  Libs/AceConsole-3.0:
    url: https://repos.wowace.com/wow/ace3/trunk/AceConsole-3.0
    tag: latest

  Libs/AceSerializer-3.0:
    url: https://repos.wowace.com/wow/ace3/trunk/AceSerializer-3.0
    tag: latest

  Libs/LibSharedMedia-3.0:
    url: https://repos.wowace.com/wow/libsharedmedia-3-0/trunk/LibSharedMedia-3.0
    tag: latest

  Libs/LibDeflate:
    url: https://github.com/SafeteeWoW/LibDeflate
    tag: latest

move-folders:
  OffBeat/OffBeat_Evoker: OffBeat_Evoker
  OffBeat/OffBeat_Monk: OffBeat_Monk
  OffBeat/OffBeat_DeathKnight: OffBeat_DeathKnight
  OffBeat/OffBeat_Paladin: OffBeat_Paladin

ignore:
  - download_deps.sh
  - download_deps.ps1
  - dev_install.sh
  - .claude
